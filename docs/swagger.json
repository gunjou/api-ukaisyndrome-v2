                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Module"
                ],
                "summary": "Get modules for a user",
                "responses": {}
            }
        },
        "/tryout/attempt/{attempt_token}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []

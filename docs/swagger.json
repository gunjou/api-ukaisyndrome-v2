                    "CDN"
                ],
                "summary": "Get mentor images",
                "responses": {}
            }
        },
        "/materi/peserta/private": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Get list materi private berdasarkan modul",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Materi"
                ],
                "summary": "Get materi private peserta",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter tipe materi (video | document)",
                        "name": "type",
                        "in": "query"
                    }
                ],
                "responses": {}
            }
        },
        "/materi/peserta/{id_modul}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Get list materi berdasarkan modul",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Materi"
                ],
                "summary": "Get materi peserta",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Modul",
                        "name": "id_modul",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Filter tipe materi (video | document)",
                        "name": "type",
                        "in": "query"
                    }
                ],
                "responses": {}
            }
        },
        "/modul/peserta": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Get a list of modules for the logged-in user based on their role",
